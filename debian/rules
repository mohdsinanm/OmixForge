#!/usr/bin/make -f

export DH_VERBOSE = 1

%:
	dh $@ --with python3

override_dh_auto_build:
	# Reconstruct the PyInstaller executable from the split parts
	cat dist/omixforge.part.* > dist/omixforge
	chmod +x dist/omixforge

override_dh_auto_test:
	# Skip tests in build environment (poetry not available)

override_dh_auto_install:
	dh_auto_install
	install -D -m 0755 debian/omixforge-wrapper debian/omixforge/usr/bin/omixforge
